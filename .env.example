# Copy this file to `.env` in the project root and replace the values below.
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Leave blank locally to keep using SQLite.
DATABASE_URL=

# Optional
DJANGO_STATIC_HOST=
SERVE_MEDIA_FILES=true
SECURE_SSL_REDIRECT=false
SITE_URL=http://127.0.0.1:8000

# Email / newsletter
# Local default can stay as console backend while you build.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=ScholarHub <hello@scholarhub.com>
SERVER_EMAIL=ScholarHub <hello@scholarhub.com>
SUPPORT_EMAIL=support@scholarhub.com

# Recommended SMTP reference:
# Brevo SMTP relay uses `smtp-relay.brevo.com` on port `587` with TLS.
